/* =========================================================
🔥 SHIN CORE LINX
Semantic Conversion Landing
========================================================= */

/* =========================================================
🔥 PAGE
========================================================= */

.page {
  max-width: 720px;
  margin: 0 auto;
  padding: 16px 16px 120px;

  color: #e5e7eb;

  background:
    linear-gradient(
      180deg,
      #020617 0%,
      #0f172a 100%
    );

  min-height: 100vh;
}

/* =========================================================
🔥 HERO
========================================================= */

.hero {
  text-align: center;

  margin-bottom: 42px;
}

.heroLabel {
  display: inline-flex;
  align-items: center;

  padding: 8px 16px;

  border-radius: 999px;

  background:
    rgba(249,115,22,0.12);

  border:
    1px solid
    rgba(249,115,22,0.22);

  color: #fdba74;

  font-size: 11px;
  font-weight: 800;

  letter-spacing: 0.12em;
  text-transform: uppercase;

  margin-bottom: 18px;
}

.heroTitle {
  font-size: 38px;
  line-height: 1.15;
  font-weight: 900;

  letter-spacing: -0.03em;

  color: #ffffff;

  margin-bottom: 18px;

  text-shadow:
    0 4px 24px rgba(249,115,22,0.12);
}

.heroDescription {
  font-size: 15px;
  line-height: 1.9;

  color: #94a3b8;

  max-width: 560px;

  margin:
    0 auto 22px;
}

/* =========================================================
🔥 HERO POINTS
========================================================= */

.heroPoints {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;

  gap: 10px;

  margin-top: 10px;
}

.heroPoint {
  padding: 10px 14px;

  border-radius: 999px;

  background:
    rgba(255,255,255,0.04);

  border:
    1px solid
    rgba(255,255,255,0.08);

  color: #e2e8f0;

  font-size: 12px;
  font-weight: 700;
}

/* =========================================================
🔥 HERO CTA
========================================================= */

.heroActions {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;

  gap: 12px;

  margin-top: 26px;
}

.heroPrimaryButton {
  display: inline-flex;
  align-items: center;
  justify-content: center;

  padding: 14px 22px;

  border-radius: 16px;

  background:
    linear-gradient(
      135deg,
      #f97316,
      #fb923c
    );

  color: #fff;

  font-size: 14px;
  font-weight: 800;

  text-decoration: none;

  box-shadow:
    0 10px 30px rgba(249,115,22,0.22);

  transition:
    transform 0.18s ease,
    opacity 0.18s ease;
}

.heroPrimaryButton:hover {
  transform: translateY(-2px);
  opacity: 0.92;
}

.heroSecondaryButton {
  display: inline-flex;
  align-items: center;
  justify-content: center;

  padding: 14px 20px;

  border-radius: 16px;

  background:
    rgba(255,255,255,0.04);

  border:
    1px solid rgba(255,255,255,0.08);

  color: #e2e8f0;

  font-size: 14px;
  font-weight: 700;

  text-decoration: none;

  transition:
    transform 0.18s ease,
    background 0.18s ease;
}

.heroSecondaryButton:hover {
  transform: translateY(-2px);

  background:
    rgba(255,255,255,0.08);
}

.heroNotice {
  margin-top: 16px;

  color: #64748b;

  font-size: 12px;
}

/* =========================================
🔥 TOP PICK
========================================= */

.topPickSection {
  margin-bottom: 56px;
}

.topPickHeader {
  text-align: center;

  margin-bottom: 24px;
}

.topPickLabel {
  display: inline-flex;
  align-items: center;
  justify-content: center;

  padding: 8px 14px;

  border-radius: 999px;

  background:
    rgba(249,115,22,0.12);

  border:
    1px solid rgba(249,115,22,0.24);

  color: #fdba74;

  font-size: 11px;
  font-weight: 800;

  letter-spacing: 0.12em;
  text-transform: uppercase;

  margin-bottom: 14px;
}

.topPickTitle {
  color: #ffffff;

  font-size: 34px;
  line-height: 1.2;
  font-weight: 900;

  letter-spacing: -0.03em;

  margin-bottom: 14px;
}

.topPickDescription {
  max-width: 560px;

  margin: 0 auto;

  color: #94a3b8;

  font-size: 15px;
  line-height: 1.9;
}

/* =========================================
🔥 PRODUCT CARD WRAP
========================================= */

.topPickCardWrap {
  margin-bottom: 18px;
}

/* =========================================
🔥 FOOTER POINTS
========================================= */

.topPickFooter {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;

  gap: 10px;
}

.topPickFooterItem {
  display: inline-flex;
  align-items: center;
  justify-content: center;

  min-height: 38px;

  padding: 10px 16px;

  border-radius: 999px;

  background:
    rgba(255,255,255,0.04);

  border:
    1px solid rgba(255,255,255,0.08);

  color: #cbd5e1;

  font-size: 13px;
  font-weight: 700;
}

/* =========================================
🔥 MOBILE
========================================= */

@media (max-width: 768px) {

  .topPickTitle {
    font-size: 28px;
  }

}


/* =========================================================
🔥 COMPARE
========================================================= */

.compareSection {
  margin-bottom: 42px;
}

.compareHeader {
  text-align: center;

  margin-bottom: 24px;
}

.compareLabel {
  color: #c084fc;

  font-size: 11px;
  font-weight: 800;

  letter-spacing: 0.12em;
  text-transform: uppercase;

  margin-bottom: 10px;
}

.compareTitle {
  color: #fff;

  font-size: 28px;
  font-weight: 900;

  margin-bottom: 10px;
}

.compareDescription {
  color: #94a3b8;

  font-size: 14px;
  line-height: 1.8;
}

.compareGrid {
  display: grid;

  grid-template-columns: 1fr;

  gap: 24px;
}

.compareItem {
  display: flex;
  flex-direction: column;

  gap: 14px;
}

.compareMeta {
  display: flex;
  flex-wrap: wrap;

  gap: 10px;
}

.compareChip,
.compareChipStrong {
  padding: 9px 14px;

  border-radius: 999px;

  font-size: 12px;
  font-weight: 700;
}

.compareChip {
  background:
    rgba(255,255,255,0.04);

  border:
    1px solid rgba(255,255,255,0.08);

  color: #cbd5e1;
}

.compareChipStrong {
  background:
    rgba(249,115,22,0.12);

  border:
    1px solid rgba(249,115,22,0.24);

  color: #fdba74;
}

/* =========================================================
🔥 INTENT NAV
========================================================= */

.intentSection {
  margin-top: 72px;
  margin-bottom: 56px;
}

.intentHeader {
  text-align: center;

  margin-bottom: 30px;
}

.intentLabel {
  display: inline-flex;

  align-items: center;

  padding:
    6px 12px;

  border-radius:
    999px;

  color:
    rgba(180,220,255,.92);

  font-size:
    11px;

  font-weight:
    800;

  letter-spacing:
    0.12em;

  text-transform:
    uppercase;

  background:
    rgba(56,189,248,0.08);

  border:
    1px solid rgba(56,189,248,0.18);

  backdrop-filter:
    blur(10px);
}

.intentTitle {
  margin-top: 18px;
  margin-bottom: 14px;

  color: #fff;

  font-size:
    clamp(2rem, 4vw, 3rem);

  font-weight:
    900;

  line-height:
    1.08;

  letter-spacing:
    -.03em;
}

.intentDescription {
  max-width:
    720px;

  margin:
    0 auto;

  color:
    rgba(148,163,184,.88);

  font-size:
    15px;

  line-height:
    1.8;
}

.intentGrid {
  display: grid;

  grid-template-columns:
    repeat(3, minmax(0, 1fr));

  gap: 20px;
}

.intentCard {
  position: relative;

  display: flex;

  flex-direction: column;

  justify-content: space-between;

  min-height: 220px;

  padding: 24px;

  overflow: hidden;

  border-radius: 28px;

  background:
    linear-gradient(
      180deg,
      rgba(20,24,34,.92),
      rgba(12,14,22,.98)
    );

  border:
    1px solid rgba(255,255,255,0.08);

  text-decoration: none;

  box-shadow:
    0 10px 30px rgba(0,0,0,.25);

  transition:
    transform .24s ease,
    border-color .24s ease,
    background .24s ease,
    box-shadow .24s ease;
}

.intentCard::before {
  content: '';

  position: absolute;

  inset: 0;

  background:
    radial-gradient(
      circle at top right,
      rgba(56,189,248,.16),
      transparent 42%
    );

  opacity: 0;

  transition:
    opacity .24s ease;
}

.intentCard:hover {
  transform:
    translateY(-6px);

  border-color:
    rgba(56,189,248,.32);

  background:
    linear-gradient(
      180deg,
      rgba(24,30,42,.96),
      rgba(14,16,24,1)
    );

  box-shadow:
    0 24px 60px rgba(0,0,0,.45),
    0 0 24px rgba(56,189,248,.16);
}

.intentCard:hover::before {
  opacity: 1;
}

.intentCardTop {
  position: relative;

  z-index: 1;

  display: flex;

  flex-direction: column;

  gap: 18px;
}

.intentIcon {
  display: flex;

  align-items: center;
  justify-content: center;

  width: 58px;
  height: 58px;

  border-radius: 18px;

  font-size: 28px;

  background:
    rgba(255,255,255,.05);

  border:
    1px solid rgba(255,255,255,.08);

  backdrop-filter:
    blur(12px);
}

.intentCardTitle {
  color: #fff;

  font-size: 18px;

  font-weight: 800;

  line-height: 1.45;
}

.intentCardText {
  margin-top: 10px;

  color:
    rgba(148,163,184,.9);

  font-size: 14px;

  line-height: 1.8;
}

.intentCardFooter {
  position: relative;

  z-index: 1;

  display: flex;

  align-items: center;

  margin-top: 28px;

  padding-top: 18px;

  border-top:
    1px solid rgba(255,255,255,.08);

  color:
    rgba(170,220,255,.95);

  font-size: 14px;

  font-weight: 700;
}

/* =========================================================
📱 TABLET
========================================================= */

@media (max-width: 980px) {

  .intentGrid {

    grid-template-columns:
      repeat(2, minmax(0, 1fr));

  }

}

/* =========================================================
📱 MOBILE
========================================================= */

@media (max-width: 640px) {

  .intentSection {
    margin-top: 56px;
    margin-bottom: 42px;
  }

  .intentGrid {

    grid-template-columns:
      1fr;

    gap: 16px;

  }

  .intentCard {

    min-height: auto;

    padding: 22px;

    border-radius: 24px;

  }

  .intentTitle {

    font-size: 2rem;

  }

  .intentCardTitle {

    font-size: 17px;

  }

}


/* =========================================================
🔥 GUIDE SECTION
========================================================= */

.guideSection {
  margin-top: 72px;
  margin-bottom: 56px;
}

/* =========================================================
HEADER
========================================================= */

.guideHeader {
  margin-bottom: 30px;
}

.guideLabel {
