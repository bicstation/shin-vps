# ---------------------------------------------------------
# ValueCommerce Reality Research
# ---------------------------------------------------------

# OAuth Credentials
VALUECOMMERCE_CLIENT_KEY=
VALUECOMMERCE_CLIENT_SECRET=

# OAuth
VALUECOMMERCE_GRANT_TYPE=client_credentials
VALUECOMMERCE_AUTH_URL=https://api.valuecommerce.com/auth/v1/affiliate/token/

# Legacy ProductDB API
VALUECOMMERCE_PRODUCTDB_URL=http://webservice.valuecommerce.ne.jp/productdb/search
VALUECOMMERCE_PRODUCTDB_TOKEN=

# OAuth Product API (Research)
VALUECOMMERCE_PRODUCT_URL=https://api.valuecommerce.com/product/v1/

# Default Observation
VALUECOMMERCE_EC_CODE=bdu9t
VALUECOMMERCE_ACCEPT=application/json

# Runtime
VALUECOMMERCE_TIMEOUT=30