{
  "extends": "./shared/tsconfig.base.json",

  "compilerOptions": {
    "baseUrl": ".",

    "jsx": "react-jsx",

    "moduleResolution": "bundler",

    "paths": {
      "@/*": ["./*"],

      "@shared/*": [
        "./shared/*",
        "../shared/*"
      ],

      "@/shared/*": [
        "./shared/*",
        "../shared/*"
      ]
    }
  },

  "include": [
    "next-env.d.ts",

    "**/*.ts",
    "**/*.tsx",

    ".next/types/**/*.ts",

    "shared/**/*.ts",
    "shared/**/*.tsx",

    "../shared/**/*.ts",
    "../shared/**/*.tsx"
  ],

  "exclude": [
    "node_modules"
  ]
}