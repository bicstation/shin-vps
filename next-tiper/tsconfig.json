{
  "extends": "../shared/tsconfig.base.json",  // 👈 ../ を追加（一つ上を見に行く）
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",                       // 👈 これを追加（React 18/19対応）
    "paths": {
      "@/*": ["./src/*", "./*"],
      /* ✅ 重要修正: 
         shared は自分のフォルダ内ではなく、一つ上の階層 (../shared) にあります。
      */
      "@shared/*": ["../shared/*"],
      "@/shared/*": ["../shared/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../shared/**/*.ts",   // 👈 ../ を追加
    "../shared/**/*.tsx",  // 👈 ../ を追加
    "../shared/**/*.css"   // 👈 ../ を追加
  ],
  "exclude": ["node_modules"]
}