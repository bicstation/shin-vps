# ====================================================================
# 1. 仮想環境・依存ライブラリ (最重要：今回混入した部分)
# ====================================================================
# プロジェクトルートおよびサブディレクトリ内の仮想環境を全て除外
analysis-env/
scraper_venv/
env/
venv/
.venv/
node_modules/
**/node_modules/

# ====================================================================
# 2. Docker / データベース永続化領域
# ====================================================================
# ホスト側のマウントボリュームデータを除外
/data/
/data_bak/
/mariadb_data/
/strapi/
mariadb_data/
strapi/
vps-data/

# ====================================================================
# 3. 機密情報・APIキー (公開厳禁)
# ====================================================================
.env
.env.*
!.env.example
client_secrets.json
token.json
**/bs_json/*.json
traefik/letsencrypt/*.json

# ====================================================================
# 4. Python / Django 関連
# ====================================================================
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ローカルDB・ログ・設定
db.sqlite3
db.sqlite3-journal
local_settings.py
*.log
pip-log.txt

# 開発中の一時コピーファイル (例: analyze_pc_spec copy.py 等を防ぐ)
* copy.py
* - コピー.py

# ====================================================================
# 5. Next.js / Frontend 関連
# ====================================================================
.next/
**/.next/
out/
**/out/
build/
**/build/
.npm
.eslintcache

# ====================================================================
# 6. スクレイピング・デバッグ用・大容量ファイル
# ====================================================================
**/debug_screenshots/
debug_*.png
debug_*.html
*.sql
*.tar.gz
*.zip
*.deb

# ====================================================================
# 7. システム / IDE (OS・エディタ)
# ====================================================================
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# 全Firebase系
config/firebase/*.json
**/firebase/*.json