{
  /* ✅ extends のパスを環境に合わせて調整 */
  "extends": "./shared/tsconfig.base.json", 
  
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "paths": {
      /* ✅ @/ 形式を優先。srcあり/なしの両方をカバー */
      "@/*": ["./src/*", "./*"],
      
      /* ✅ Docker(shared/*) と ローカル(../shared/*) の両方を解決 */
      "@shared/*": ["./shared/*", "../shared/*"],
      "@/shared/*": ["./shared/*", "../shared/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    /* ✅ 型定義の読み込み範囲を確実に確保 */
    "./shared/**/*.ts",
    "./shared/**/*.tsx",
    "../shared/**/*.ts",
    "../shared/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}