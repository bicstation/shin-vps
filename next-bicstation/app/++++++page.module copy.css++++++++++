  align-items: center;

  padding:
    6px 12px;

  border-radius:
    999px;

  color:
    rgba(250,204,21,.95);

  font-size:
    11px;

  font-weight:
    800;

  letter-spacing:
    0.12em;

  text-transform:
    uppercase;

  background:
    rgba(250,204,21,.08);

  border:
    1px solid rgba(250,204,21,.18);

  backdrop-filter:
    blur(10px);

  margin-bottom:
    14px;
}

.guideTitle {
  color: #fff;

  font-size:
    clamp(2rem, 4vw, 3rem);

  font-weight:
    900;

  line-height:
    1.08;

  letter-spacing:
    -.03em;

  margin-bottom:
    18px;
}

.guideDescription {
  max-width:
    720px;

  color:
    rgba(148,163,184,.92);

  font-size:
    15px;

  line-height:
    1.9;
}

/* =========================================================
GRID
========================================================= */

.guideGrid {
  display: grid;

  grid-template-columns:
    repeat(2, minmax(0, 1fr));

  gap: 18px;
}

/* =========================================================
CARD
========================================================= */

.guideCard {
  position: relative;

  display: flex;

  flex-direction: column;

  justify-content: space-between;

  min-height: 240px;

  padding: 24px;

  overflow: hidden;

  border-radius: 24px;

  background:
    linear-gradient(
      180deg,
      rgba(20,24,34,.92),
      rgba(12,14,22,.98)
    );

  border:
    1px solid rgba(255,255,255,0.08);

  text-decoration: none;

  transition:
    transform .22s ease,
    border-color .22s ease,
    background .22s ease,
    box-shadow .22s ease;
}

.guideCard::before {
  content: '';

  position: absolute;

  inset: 0;

  background:
    radial-gradient(
      circle at top right,
      rgba(250,204,21,.10),
      transparent 42%
    );

  opacity: 0;

  transition:
    opacity .22s ease;
}

.guideCard:hover {
  transform:
    translateY(-4px);

  border-color:
    rgba(250,204,21,.24);

  box-shadow:
    0 18px 48px rgba(0,0,0,.38);

  background:
    linear-gradient(
      180deg,
      rgba(24,28,40,.96),
      rgba(14,16,24,1)
    );
}

.guideCard:hover::before {
  opacity: 1;
}

/* =========================================================
TOP
========================================================= */

.guideCardTop {
  position: relative;

  z-index: 1;
}

/* =========================================================
BADGE
========================================================= */

.guideCardBadge {
  display: inline-flex;

  align-items: center;

  padding:
    6px 10px;

  border-radius:
    999px;

  background:
    rgba(255,255,255,.06);

  border:
    1px solid rgba(255,255,255,.08);

  color:
    rgba(255,255,255,.88);

  font-size:
    11px;

  font-weight:
    700;

  margin-bottom:
    18px;
}

/* =========================================================
TITLE
========================================================= */

.guideCardTitle {
  color: #fff;

  font-size:
    20px;

  font-weight:
    800;

  line-height:
    1.45;

  margin-bottom:
    14px;
}

/* =========================================================
DESCRIPTION
========================================================= */

.guideCardDescription {
  color:
    rgba(226,232,240,.88);

  font-size:
    14px;

  line-height:
    1.9;
}

/* =========================================================
ACTION
========================================================= */

.guideCardAction {
  position: relative;

  z-index: 1;

  margin-top:
    28px;

  padding-top:
    18px;

  border-top:
    1px solid rgba(255,255,255,.08);

  color:
    rgba(255,255,255,.94);

  font-size:
    14px;

  font-weight:
    800;

  transition:
    color .18s ease;
}

.guideCard:hover .guideCardAction {
  color:
    rgba(250,204,21,.95);
}

/* =========================================================
TABLET
========================================================= */

@media (max-width: 980px) {

  .guideGrid {

    grid-template-columns:
      1fr;

  }

}

/* =========================================================
MOBILE
========================================================= */

@media (max-width: 640px) {

  .guideSection {
    margin-top: 56px;
    margin-bottom: 42px;
  }

  .guideCard {
    min-height: auto;

    padding: 22px;

    border-radius: 22px;
  }

  .guideTitle {
    font-size: 2rem;
  }

  .guideCardTitle {
    font-size: 18px;
  }

}


/* =========================================================
🔥 POPULAR SECTION
========================================================= */

.popularSection {
  margin-bottom: 56px;
}

/* =========================================================
🔥 HEADER
========================================================= */

.popularHeader {
