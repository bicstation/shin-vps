digraph SemanticReality {

    rankdir=LR;

    graph [fontname="Helvetica"];
    node  [fontname="Helvetica"];
    edge  [fontname="Helvetica"];

    // Universe

    "usage" [shape=folder,label="用途"];
    "device" [shape=folder,label="デバイス"];
    "gpu" [shape=folder,label="GPU"];
    "cpu" [shape=folder,label="CPU"];
    "memory" [shape=folder,label="メモリ"];
    "storage" [shape=folder,label="ストレージ"];
    "monitor" [shape=folder,label="モニター"];
    "maker" [shape=folder,label="メーカー"];
    "adult" [shape=folder,label="アダルト"];

    // Group

    "gpu-highend" [shape=box,label="AI・ゲーム"];
    "cpu-ai" [shape=box,label="AI"];
    "memory-highend" [shape=box,label="大容量"];
    "storage-highend" [shape=box,label="大容量保存"];
