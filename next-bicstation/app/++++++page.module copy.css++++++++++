}

.popularTitle {
  color: #ffffff;

  font-size: 34px;
  line-height: 1.2;
  font-weight: 900;

  letter-spacing: -0.03em;

  margin-bottom: 14px;
}

.popularDescription {
  max-width: 560px;

  margin: 0 auto;

  color: #94a3b8;

  font-size: 15px;
  line-height: 1.9;
}

/* =========================================================
🔥 GRID
========================================================= */

.popularGrid {
  display: grid;

  grid-template-columns:
    repeat(2, 1fr);

  gap: 18px;
}

/* =========================================================
🔥 CARD
========================================================= */

.popularCard {
  position: relative;

