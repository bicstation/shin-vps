{
  /* ✅ ポイント1: extends のパスを `./` にする */
  "extends": "./shared/tsconfig.base.json", 
  
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*", "./*"],
      /* ✅ ポイント2: Dockerの構造にあわせつつ、VS Codeでも通る書き方 */
      "@shared/*": ["shared/*", "../shared/*"],
      "@/shared/*": ["shared/*", "../shared/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    /* ✅ ポイント3: 両方の可能性を含める */
    "shared/**/*.ts",
    "shared/**/*.tsx",
    "../shared/**/*.ts",
    "../shared/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}