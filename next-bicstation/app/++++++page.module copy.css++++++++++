  align-items: center;
  justify-content: center;

  gap:
    8px;

  min-height:
    54px;

  padding:
    0 26px;

  border-radius:
    16px;

  background:
    linear-gradient(
      135deg,
      #f97316,
      #fb923c
    );

  color:
    #fff;

  font-size:
    14px;

  font-weight:
    800;

  text-decoration:
    none;

  box-shadow:
    0 12px 32px rgba(249,115,22,.24);

  transition:
    transform .2s ease,
    box-shadow .2s ease,
    opacity .2s ease;
}

.bottomButton:hover {
  transform:
    translateY(-2px);

  opacity:
    .96;

  box-shadow:
    0 16px 40px rgba(249,115,22,.30);
}

/* =========================================================
TABLET
========================================================= */

@media (max-width: 980px) {

  .bottomCard {

    padding:
      36px 24px;

    border-radius:
      26px;

  }

}

/* =========================================================
MOBILE
========================================================= */

@media (max-width: 640px) {

  .bottomSection {
    margin-top: 48px;
    margin-bottom: 48px;
  }

  .bottomCard {

    padding:
      32px 20px;

    border-radius:
      24px;

  }

  .bottomTitle {

    font-size:
      1.9rem;

    line-height:
      1.25;

  }

  .bottomDescription {

    font-size:
      14px;

    line-height:
      1.8;

  }

  .bottomFeatures {

    flex-direction:
      column;

    align-items:
      stretch;

    gap:
      8px;

  }

  .bottomFeature {

    justify-content:
      center;

  }

  .bottomButton {

    width:
      100%;

    min-height:
      52px;

  }

}


/* =========================================
🔥 STICKY CTA
========================================= */

.stickyCTA {
  position: fixed;

  left: 50%;
  bottom: 14px;

  transform: translateX(-50%);

  width:
    calc(100% - 24px);

  max-width:
    720px;

  display: flex;

  gap: 12px;

  z-index: 999;

  padding:
    10px;

  border-radius:
    24px;

  background:
    rgba(15,23,42,.58);

  border:
    1px solid rgba(255,255,255,.06);

  backdrop-filter:
    blur(18px);

  box-shadow:
    0 18px 48px rgba(0,0,0,.34);
}

/* =========================================
🔥 PRIMARY
========================================= */

.stickyPrimary {
  flex: 1;

  display: inline-flex;

  align-items: center;
  justify-content: center;

  gap:
    8px;

  min-height:
    58px;

  padding:
    14px 20px;

  border-radius:
    18px;

  background:
    linear-gradient(
      135deg,
      #f97316,
      #fb923c
    );

  color:
    #ffffff;

  font-size:
    14px;

  font-weight:
    900;

  letter-spacing:
    -.01em;

  text-decoration:
    none;

  box-shadow:
    0 14px 40px rgba(249,115,22,.28);

  transition:
    transform .18s ease,
    opacity .18s ease,
    box-shadow .18s ease;
}

.stickyPrimary:hover {
  transform:
    translateY(-2px);

  opacity:
    .96;

  box-shadow:
    0 18px 48px rgba(249,115,22,.36);
}

/* =========================================
🔥 SECONDARY
========================================= */

.stickySecondary {
  flex: 1;

  display: inline-flex;

  align-items: center;
  justify-content: center;

  gap:
    8px;

  min-height:
    58px;

  padding:
    14px 20px;

  border-radius:
    18px;

  background:
    rgba(255,255,255,.05);

  border:
    1px solid rgba(255,255,255,.08);

  color:
    #e2e8f0;

  font-size:
    14px;

  font-weight:
    800;

  letter-spacing:
    -.01em;

  text-decoration:
    none;

  backdrop-filter:
    blur(12px);

  transition:
    transform .18s ease,
    border-color .18s ease,
    background .18s ease,
    color .18s ease;
}

.stickySecondary:hover {
  transform:
    translateY(-2px);

  border-color:
    rgba(249,115,22,.22);

  background:
    rgba(255,255,255,.08);

  color:
    #ffffff;
}

/* =========================================
🔥 MOBILE SAFE AREA
========================================= */

@supports (
  padding-bottom:
  env(safe-area-inset-bottom)
) {

  .stickyCTA {

    bottom:
      calc(
        14px +
        env(safe-area-inset-bottom)
      );

  }

}

/* =========================================
🔥 MOBILE
========================================= */

@media (max-width: 640px) {

  .stickyCTA {

    gap:
      10px;

    padding:
      8px;

    border-radius:
      20px;

  }

  .stickyPrimary,
  .stickySecondary {

    min-height:
      54px;

    font-size:
      13px;

    border-radius:
      16px;

    padding:
      12px 14px;

  }

}

/* =========================================================
🔥 EMPTY
========================================================= */

.empty {
  min-height: 60vh;

  display: flex;
  align-items: center;
  justify-content: center;
}

.emptyCard {
  width: 100%;
  max-width: 420px;

  padding: 30px;

  border-radius: 24px;

  background:
    rgba(255,255,255,0.03);

  border:
    1px solid rgba(255,255,255,0.06);

  text-align: center;
}

.emptyTitle {
  color: #fff;

  font-size: 22px;
  font-weight: 900;

  margin-bottom: 12px;
}

.emptyText {
  color: #94a3b8;

  font-size: 14px;
  line-height: 1.8;
}

/* =========================================================
🔥 RESPONSIVE
========================================================= */

@media (max-width: 640px) {

  .heroTitle {
    font-size: 30px;
  }

  .compareTitle,
  .intentTitle,
  .guideTitle,
  .popularTitle,
  .bottomTitle {
    font-size: 24px;
  }

  .intentGrid {
    grid-template-columns: 1fr;
  }

  .stickyCTA {
    bottom: 10px;
  }

}