{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    
    /* ✅ 1. Next.js 15 推奨: bundler 解決 */
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,

    /* ✅ 2. ベースディレクトリ設定 */
    "baseUrl": ".",

    /* ✅ 3. エイリアス定義 (django を追加) */
    "paths": {
      "@/*": ["./*"],
      "@django/*": ["django/*"],
      "@shared/*": ["shared/*"],
      "@shared/components/*": ["shared/components/*"],
      "@shared/atoms/*": ["shared/components/atoms/*"],
      "@shared/molecules/*": ["shared/components/molecules/*"],
      "@shared/organisms/*": ["shared/components/organisms/*"],
      "@shared/templates/*": ["shared/components/templates/*"],
      "@shared/lib/*": ["shared/lib/*"],
      "@shared/api/*": ["shared/lib/api/*"],
      "@shared/utils/*": ["shared/lib/utils/*"],
      "@shared/styles/*": ["shared/styles/*"],
      "@shared/types": ["shared/types/index.ts"]
    }
  },

  /* ✅ 4. ビルド・型チェック対象 (django を追加) */
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    
    /* 外部ディレクトリの定義を明示的に含める */
    "django/**/*.ts",
    "shared/components/**/*.ts",
    "shared/components/**/*.tsx",
    "shared/lib/**/*.ts",
    "shared/lib/**/*.tsx",
    "shared/styles/**/*.css",
    "shared/types/**/*.ts"
  ],

  "exclude": ["node_modules"]
}