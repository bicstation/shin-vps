{
  "extends": "../shared/tsconfig.base.json",  // 👈 ここも ../ を追加
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",                       // 👈 React 18/19 の赤線を消す魔法
    "paths": {
      "@/*": ["./src/*", "./*"],
      /* ✅ 修正の要: 
         shared は自分のフォルダ内ではなく、一つ上の階層 (../shared) にあります。
      */
      "@shared/*": ["../shared/*"],
      "@/shared/*": ["../shared/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../shared/**/*.ts",   // 👈 一つ上を見に行くように修正
    "../shared/**/*.tsx",  // 👈 一つ上を見に行くように修正
    "../shared/**/*.css"   // 👈 一つ上を見に行くように修正
  ],
  "exclude": ["node_modules"]
}